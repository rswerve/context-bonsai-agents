+                to_pattern: "beta completed".to_string(),
+                summary: "finished alpha and beta work".to_string(),
+                index_terms: vec!["alpha".to_string(), "beta".to_string()],
+                reason: Some("completed".to_string()),
+            },
+        )
+        .expect("prune should succeed");
+
+        assert_eq!(install.archive_payload.archived_history, history[..2]);
+        assert_eq!(install.replacement_history.len(), 2);
+        assert!(install.placeholder_text.starts_with("[PRUNED:"));
+
+        let restored = build_retrieve_install(
+            &install.replacement_history,
+            &install.archive_payload,
+            false,
+        )
+        .expect("retrieve should succeed");
+        assert_eq!(restored, history);
+    }
+
+    #[test]
+    fn current_turn_is_excluded_from_boundary_matching() {
+        let history = vec![
+            message("user", "historical unique boundary"),
+            message("assistant", "historical completed reply"),
+            message(
+                "user",
+                "prune the message containing historical unique boundary",
+            ),
+            message(
+                "assistant",
+                "reasoning repeats historical unique boundary before the tool call",
+            ),
+        ];
+        let protected = prune_protected_flags(&history);
+        assert_eq!(protected, vec![false, false, true, true]);
+
+        let install = build_prune_install(
+            &history,
+            &protected,
+            PruneArgs {
+                from_pattern: "historical unique boundary".to_string(),
+                to_pattern: "historical completed reply".to_string(),
+                summary: "completed historical work".to_string(),
+                index_terms: vec!["historical".to_string()],
+                reason: None,
+            },
+        )
+        .expect("current-turn repetitions must not make old boundaries ambiguous");
+
+        assert_eq!(install.archive_payload.archived_history, history[..2]);
+        assert_eq!(install.replacement_history[1..], history[2..]);
+    }
+
+    #[test]
+    fn existing_placeholder_is_protected_from_nested_prune() {
+        let history = vec![
+            message(
+                "assistant",
+                "[PRUNED: prior-anchor to prior-end]\nSummary: prior\nIndex: prior",
+            ),
+            message("assistant", "later completed reply"),
+            message("user", "prune old completed work"),
+        ];
+        let protected = prune_protected_flags(&history);
+
+        assert_eq!(protected, vec![true, false, true]);
+        let error = build_prune_install(
+            &history,
+            &protected,
+            PruneArgs {
+                from_pattern: "prior-anchor".to_string(),
+                to_pattern: "later completed reply".to_string(),
+                summary: "nested archive".to_string(),
+                index_terms: vec!["nested".to_string()],
+                reason: None,
+            },
+        )
+        .expect_err("an existing retrieval placeholder must not be re-archived");
+
+        assert!(matches!(error, GuardError::NoMatch { which: "from" }));
+    }
+
+    #[test]
+    fn persisted_archive_survives_a_fresh_load() {
+        let codex_home = tempfile::tempdir().expect("create temporary CODEX_HOME");
+        let thread_id = "019f-test-thread";
+        let archive = BonsaiArchivePayload::new(
+            BonsaiArchiveMeta {
+                anchor_id: "bonsai-anchor-persisted".to_string(),
+                range_end_id: "bonsai-anchor-end".to_string(),
+                summary: "persisted completed work".to_string(),
+                index_terms: vec!["persisted".to_string()],
+                reason: None,
+            },
+            vec![message("user", "archived payload")],
+        );
+
+        persist_archive_sync(codex_home.path(), thread_id, &archive).expect("persist archive");
+        let loaded = load_archive_sync(codex_home.path(), thread_id, &archive.meta.anchor_id)
+            .expect("load archive in a fresh operation");
+
+        assert_eq!(loaded, archive);
+    }
+
+    #[test]
+    fn persisted_archives_are_thread_scoped() {
+        let codex_home = tempfile::tempdir().expect("create temporary CODEX_HOME");
+        let archive = BonsaiArchivePayload::new(
+            BonsaiArchiveMeta {
+                anchor_id: "bonsai-anchor-scoped".to_string(),
+                range_end_id: "bonsai-anchor-end".to_string(),
+                summary: "thread scoped work".to_string(),
+                index_terms: vec!["scoped".to_string()],
+                reason: None,
+            },
+            vec![message("assistant", "only thread A can retrieve this")],
+        );
+
+        persist_archive_sync(codex_home.path(), "thread-a", &archive).expect("persist archive");
+        let error = load_archive_sync(codex_home.path(), "thread-b", &archive.meta.anchor_id)
+            .expect_err("thread B must not read thread A archive");
+
+        assert!(matches!(error, ArchiveStoreError::Missing { .. }));
+    }
+}

diff --git a/codex-rs/core/src/tools/handlers/bonsai.rs b/codex-rs/core/src/tools/handlers/bonsai.rs
new file mode 100644
index 0000000..c05b3bd
--- /dev/null
+++ b/codex-rs/core/src/tools/handlers/bonsai.rs
@@ -0,0 +1,216 @@
+use std::collections::BTreeMap;
+
+use codex_tools::JsonSchema;
+use codex_tools::ResponsesApiTool;
+use codex_tools::ToolName;
+use codex_tools::ToolSpec;
+use serde::Deserialize;
+
+use crate::context_bonsai::PruneArgs;
+use crate::context_bonsai::build_prune_install;
+use crate::context_bonsai::prune_protected_flags;
+use crate::function_tool::FunctionCallError;
+use crate::tools::context::FunctionToolOutput;
+use crate::tools::context::ToolInvocation;
+use crate::tools::context::ToolPayload;
+use crate::tools::context::boxed_tool_output;
+use crate::tools::handlers::parse_arguments;
+use crate::tools::registry::CoreToolRuntime;
+use crate::tools::registry::ToolExecutor;
+
+pub(crate) const PRUNE_TOOL_NAME: &str = "context-bonsai-prune";
+pub(crate) const RETRIEVE_TOOL_NAME: &str = "context-bonsai-retrieve";
+
+fn prune_spec() -> ToolSpec {
+    let properties = BTreeMap::from([
+        (
+            "from_pattern".to_string(),
+            JsonSchema::string(Some(
+                "Unique substring identifying the first transcript item to archive.".to_string(),
+            )),
+        ),
+        (
+            "to_pattern".to_string(),
+            JsonSchema::string(Some(
+                "Unique substring identifying the last transcript item to archive.".to_string(),
+            )),
+        ),
+        (
+            "summary".to_string(),
+            JsonSchema::string(Some(
+                "Short summary retained in the replacement placeholder.".to_string(),
+            )),
+        ),
+        (
+            "index_terms".to_string(),
+            JsonSchema::array(
+                JsonSchema::string(None),
+                Some("Terms that make the archive discoverable later.".to_string()),
+            ),
+        ),
+        (
+            "reason".to_string(),
+            JsonSchema::string(Some(
+                "Optional reason for pruning this completed range.".to_string(),
+            )),
+        ),
+    ]);
+    ToolSpec::Function(ResponsesApiTool {
+        name: PRUNE_TOOL_NAME.to_string(),
+        description: "Archive a completed contiguous transcript range and replace it with a recoverable summary placeholder.".to_string(),
+        strict: false,
+        defer_loading: None,
+        parameters: JsonSchema::object(properties, Some(vec!["from_pattern".to_string(), "to_pattern".to_string(), "summary".to_string(), "index_terms".to_string()]), Some(false.into())),
+        output_schema: None,
+    })
+}
+
+fn retrieve_spec() -> ToolSpec {
+    let properties = BTreeMap::from([(
+        "anchor_id".to_string(),
+        JsonSchema::string(Some(
+            "Anchor id returned by context-bonsai-prune.".to_string(),
+        )),
+    )]);
+    ToolSpec::Function(ResponsesApiTool {
+        name: RETRIEVE_TOOL_NAME.to_string(),
+        description: "Restore an archived Context Bonsai range into the live transcript."
+            .to_string(),
+        strict: false,
+        defer_loading: None,
+        parameters: JsonSchema::object(
+            properties,
+            Some(vec!["anchor_id".to_string()]),
+            Some(false.into()),
+        ),
+        output_schema: None,
+    })
+}
+
+#[derive(Debug, Deserialize)]
+struct PruneArgsWire {
+    from_pattern: String,
+    to_pattern: String,
+    summary: String,
+    #[serde(default)]
+    index_terms: Vec<String>,
+    #[serde(default)]
+    reason: Option<String>,
+}
+
+pub struct ContextBonsaiPruneHandler;
+
+impl ToolExecutor<ToolInvocation> for ContextBonsaiPruneHandler {
+    fn tool_name(&self) -> ToolName {
+        ToolName::plain(PRUNE_TOOL_NAME)
+    }
+
+    fn spec(&self) -> ToolSpec {
+        prune_spec()
+    }
+
+    fn handle(&self, invocation: ToolInvocation) -> codex_tools::ToolExecutorFuture<'_> {
+        Box::pin(async move {
+            let ToolInvocation {
+                session,
+                turn,
+                payload,
+                ..
+            } = invocation;
+            let ToolPayload::Function { arguments } = payload else {
+                return Err(FunctionCallError::RespondToModel(
+                    "context-bonsai-prune received an unsupported payload".to_string(),
+                ));
+            };
+            let wire: PruneArgsWire = parse_arguments(&arguments)?;
+            let history = session.clone_history().await.into_raw_items();
+            let archived_flags = prune_protected_flags(&history);
+            let install = build_prune_install(
+                &history,
+                &archived_flags,
+                PruneArgs {
+                    from_pattern: wire.from_pattern,
+                    to_pattern: wire.to_pattern,
+                    summary: wire.summary,
+                    index_terms: wire.index_terms,
+                    reason: wire.reason,
+                },
+            )
+            .map_err(|error| {
+                FunctionCallError::RespondToModel(format!("context-bonsai-prune rejected: {error}"))
+            })?;
+            let anchor_id = install.anchor_id.clone();
+            let range_end_id = install.range_end_id.clone();
+            session
+                .apply_bonsai_prune(turn.as_ref(), install)
+                .await
+                .map_err(|error| {
+                    FunctionCallError::RespondToModel(format!(
+                        "context-bonsai-prune persistence failed: {error}"
+                    ))
+                })?;
+            Ok(boxed_tool_output(FunctionToolOutput::from_text(
+                format!(
+                    "Archived range {anchor_id} to {range_end_id}. Use context-bonsai-retrieve with anchor_id {anchor_id} to restore it."
+                ),
+                Some(true),
+            )))
+        })
+    }
+}
+
+impl CoreToolRuntime for ContextBonsaiPruneHandler {}
+
+#[derive(Debug, Deserialize)]
+struct RetrieveArgsWire {
+    anchor_id: String,
+}
+
+pub struct ContextBonsaiRetrieveHandler;
+
+impl ToolExecutor<ToolInvocation> for ContextBonsaiRetrieveHandler {
+    fn tool_name(&self) -> ToolName {
+        ToolName::plain(RETRIEVE_TOOL_NAME)
+    }
+
+    fn spec(&self) -> ToolSpec {
+        retrieve_spec()
+    }
+
+    fn handle(&self, invocation: ToolInvocation) -> codex_tools::ToolExecutorFuture<'_> {
+        Box::pin(async move {
+            let ToolInvocation {
+                session,
+                turn,
+                payload,
+                ..
+            } = invocation;
+            let ToolPayload::Function { arguments } = payload else {
+                return Err(FunctionCallError::RespondToModel(
+                    "context-bonsai-retrieve received an unsupported payload".to_string(),
+                ));
+            };
+            let wire: RetrieveArgsWire = parse_arguments(&arguments)?;
+            let anchor_id = wire.anchor_id.trim().to_string();
+            if anchor_id.is_empty() {
+                return Err(FunctionCallError::RespondToModel(
+                    "anchor_id must be non-empty".to_string(),
+                ));
+            }
+            session
+                .apply_bonsai_retrieve(turn.as_ref(), &anchor_id)
+                .await
+                .map_err(|error| {
+                    FunctionCallError::RespondToModel(format!(
+                        "context-bonsai-retrieve rejected: {error}"
+                    ))
+                })?;
+            Ok(boxed_tool_output(FunctionToolOutput::from_text(
+                format!("Restored bonsai archive {anchor_id} into the live transcript."),
+                Some(true),
+            )))
+        })
+    }
+}
+
+impl CoreToolRuntime for ContextBonsaiRetrieveHandler {}
